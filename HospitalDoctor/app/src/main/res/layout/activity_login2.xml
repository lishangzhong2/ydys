<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/bg_login">

    <LinearLayout
        android:id="@+id/infoErea"
        android:layout_width="322dp"
        android:layout_height="265dp"
        android:layout_centerInParent="true"
        android:background="@mipmap/bg_login_frame"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/login_bg"
            android:layout_width="190dp"
            android:layout_height="28dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="35dp"
            android:src="@mipmap/ic_login_title"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="252dp"
            android:layout_height="28dp"
            android:background="#0F557F"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@mipmap/ic_accountpic" />

            <AutoCompleteTextView
                android:id="@+id/email"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="28dp"
                android:background="@mipmap/bg_edit"
                android:hint="@string/account"
                android:paddingLeft="@dimen/drawable_padding_5dp"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textColorHint="#71aed3"
                android:textSize="@dimen/textSize_12sp"
                tools:ignore="TextFields" />
            <ImageView
                android:id="@+id/iv_moreunfold"
                android:layout_width="28dp"
                android:background="@mipmap/more_unfold"
                android:layout_margin="2dp"
                android:layout_height="match_parent" />
        </LinearLayout>
        <!-- 启用ca 把ll_pwd 设置为显示状态-->
        <!--android:visibility="gone"-->
        <LinearLayout
            android:id="@+id/ll_pwd"
            android:layout_width="252dp"
            android:layout_height="28dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/mar20dp"
            android:visibility="visible">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@mipmap/ic_passwordpic" />

            <EditText
                android:id="@+id/password"
                android:layout_width="224dp"
                android:layout_height="28dp"
                android:background="@mipmap/bg_edit"
                android:hint="@string/password"
                android:inputType="textPassword"
                android:paddingLeft="@dimen/drawable_padding_5dp"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textColorHint="#71aed3"
                android:textSize="@dimen/textSize_12sp"

                tools:ignore="TextFields" />
        </LinearLayout>

        <Button
            android:id="@+id/email_sign_in_button"
            android:layout_width="252dp"
            android:layout_height="28dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="25dp"
            android:background="@mipmap/ic_login" />

        <ProgressBar
            android:id="@+id/login_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="252dp"
            android:layout_marginTop="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_height="28dp">
            <TextView
                android:id="@+id/tv_wjmm"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="忘记PIN码"
                android:visibility="gone"
                android:gravity="bottom"
                android:textColor="@color/white"
                android:onClick="forgotpwd"
                />
            <View android:layout_weight="1"
                android:layout_height="0dp"
                android:layout_width="0dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="下载证书"
                android:id="@+id/tv_xzzs"
                android:visibility="gone"
                android:gravity="bottom|right"
                android:textColor="@color/white"
                android:onClick="forgotpwd"
                />
        </LinearLayout>


        <!--<ImageView-->
        <!--android:id="@+id/iv_setIP"-->
        <!--android:layout_width="25dp"-->
        <!--android:layout_height="25dp"-->
        <!--android:layout_marginLeft="110dp"-->
        <!--android:layout_marginStart="110dp"-->
        <!--android:layout_marginTop="350dp"-->
        <!--android:layout_toEndOf="@id/password"-->
        <!--android:layout_toRightOf="@id/password"-->
        <!--android:src="@drawable/ic_setip"-->
        <!--tools:ignore="ContentDescription" />-->
    </LinearLayout>

</RelativeLayout>