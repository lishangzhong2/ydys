<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_nav_item"
    android:layout_width="23dp"
    android:layout_height="23dp"
    android:layout_marginTop="@dimen/mar10dp"
    android:background="@mipmap/bg_nav"
    android:orientation="horizontal"
    >

    <TextView
        android:id="@+id/card_start"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:textColor="#fffeff"
        android:textSize="@dimen/textSize_12sp"
        android:textStyle="bold"
        android:visibility="gone"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="~"
        android:textColor="#fffeff"
        android:textSize="@dimen/textSize_12sp"
        android:textStyle="bold"
        android:visibility="gone"
        />

    <TextView
        android:id="@+id/card_end"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:textColor="#fffeff"
        android:textSize="@dimen/textSize_10sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        />

</LinearLayout>