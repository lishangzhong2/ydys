<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chineseDrugArea"
    android:layout_width="700dp"
    android:layout_height="475dp"
    android:background="@drawable/bg_card_shadow"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="140dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/mar10dp"
            android:gravity="center_vertical"
            android:text="处方列表"
            android:textColor="@android:color/black"
            android:textSize="@dimen/textSize_12sp"
            android:textStyle="bold" />

        <View
            style="@style/view_commonHoriGrey"
            android:layout_marginTop="@dimen/mar10dp" />

        <ListView
            android:id="@+id/herbal_pop_fatherList"
            android:layout_width="140dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingLeft="@dimen/drawable_padding_5dp" />
    </LinearLayout>

    <View style="@style/view_commonVert" />

    <LinearLayout
        android:layout_width="@dimen/size0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/containerHeight"
            android:layout_marginLeft="0dp"
            android:layout_marginTop="@dimen/padding7dp">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="@dimen/mar10dp"
                android:text="处方明细"
                android:textColor="@android:color/black"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/herbal_iv_change"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginLeft="60dp"
                android:layout_marginTop="12dp"
                android:src="@mipmap/change2"
                android:visibility="visible" />

            <Button
                android:id="@+id/herbal_cf_add"
                android:layout_width="53dp"
                android:layout_height="23dp"
                android:layout_alignBottom="@+id/textView"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginEnd="27dp"
                android:layout_marginRight="27dp"
                android:background="@android:color/holo_green_light"
                android:text="新增"
                android:textColor="@android:color/white"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/herbal_iv_modify"
                android:layout_width="53dp"
                android:layout_height="23dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginLeft="129dp"
                android:layout_marginStart="129dp"
                android:src="@mipmap/ic_modify"
                android:visibility="gone" />
        </RelativeLayout>

        <View
            style="@style/view_commonHoriGrey"
            android:layout_marginLeft="@dimen/padding7dp" />

        <android.support.v7.widget.RecyclerView
            android:id="@+id/herbal_savedList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp" />
    </LinearLayout>

    <View style="@style/view_commonVert" />

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/drawable_padding_5dp"
        android:layout_marginRight="@dimen/drawable_padding_5dp"
        android:layout_marginTop="@dimen/drawable_padding_5dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:layout_marginTop="25dp"
                android:text="中草药处方明细:"
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_12sp" />

            <ImageView
                android:id="@+id/herbal_iv_delete"
                android:layout_width="53dp"
                android:layout_height="23dp"
                android:layout_marginLeft="@dimen/mar10dp"
                android:layout_marginRight="@dimen/mar20dp"
                android:layout_marginTop="@dimen/mar10dp"
                android:src="@mipmap/ic_delete"
                android:visibility="visible" />

            <Button
                android:id="@+id/herbal_cf_finish"
                android:layout_width="53dp"
                android:layout_height="23dp"
                android:layout_alignBottom="@+id/textView"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_marginEnd="28dp"
                android:layout_marginRight="28dp"
                android:layout_marginTop="@dimen/mar10dp"
                android:background="@android:color/holo_green_light"
                android:text="完成"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">
<!--            android:layout_marginTop="@dimen/mar10dp"-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="药品名称："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_ypmc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="剂量："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <ImageView
                android:id="@+id/herbal_iv_decrease"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginLeft="@dimen/marginCommon"
                android:src="@mipmap/ic_luru_decrease" />

            <EditText
                android:id="@+id/herbal_et_jl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/drawable_padding_3dp"
                android:inputType="numberDecimal"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />

            <ImageView
                android:id="@+id/herbal_iv_add"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginLeft="@dimen/drawable_padding_5dp"
                android:src="@mipmap/ic_luru_add" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:text="单位："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_jldw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/mar10dp"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="库存提示："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_kcts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:paddingLeft="40dp"
            android:paddingBottom="@dimen/drawable_padding_5dp">
<!--            android:paddingBottom="@dimen/mar20dp"-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="备注："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <EditText
                android:id="@+id/herbal_et_bz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:layout_marginRight="38dp"
                android:singleLine="true"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>
        <View
            style="@style/view_commonHoriGrey"
            android:layout_alignParentBottom="true" />



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical"
            android:paddingLeft="@dimen/marginCommon">
<!--            android:layout_marginTop="20dp"-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中草药处方大项信息："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_12sp" />

            <ImageView
                android:id="@+id/herbal_iv_commonDrug"
                android:layout_width="54dp"
                android:layout_height="24dp"
                android:layout_marginLeft="@dimen/margin"
                android:src="@mipmap/ic_commondrug"
                android:visibility="visible" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="付数："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <ImageView
                android:id="@+id/sl_iv_decrease"
                android:layout_width="@dimen/mar12dp"
                android:layout_height="@dimen/mar12dp"
                android:layout_marginLeft="@dimen/marginCommon"
                android:src="@mipmap/ic_luru_decrease"
                android:visibility="gone" />

            <EditText
                android:id="@+id/herbal_et_sl"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/drawable_padding_5dp"
                android:inputType="number"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />

            <ImageView
                android:id="@+id/sl_iv_add"
                android:layout_width="@dimen/mar12dp"
                android:layout_height="@dimen/mar12dp"
                android:layout_marginLeft="@dimen/drawable_padding_5dp"
                android:src="@mipmap/ic_luru_add"
                android:visibility="gone" />

            <TextView
                android:id="@+id/herbal_tv_sldw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/drawable_padding_3dp"
                android:textColor="@color/grey999"
                android:textSize="@dimen/textSize_10sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="嘱托："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <EditText
                android:id="@+id/herbal_et_zhutuo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:layout_marginRight="38dp"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="给药频率："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_pl"
                android:prompt="@style/myDialogTheme"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="给药方式："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_gyfs"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="熬(煎)药方式："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_ayfs"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_djfa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="代煎方案："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_djfa"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_jzjl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="煎煮剂量："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_jzjl"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/drawable_padding_3dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服用要求："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <Spinner
                android:id="@+id/herbal_sp_fyyq"
                style="@style/herbalWindowSpinnerStyle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding7dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取药药房："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_qyyf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/mar12dp"
            android:paddingLeft="40dp"
            android:visibility="gone"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="参考总金额："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_money"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:textColor="#cc3636"
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mar12dp"
            android:gravity="center_vertical"
            android:paddingLeft="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="处方单号："
                android:textColor="@color/textBlack"
                android:textSize="@dimen/textSize_10sp" />

            <TextView
                android:id="@+id/herbal_tv_cfdh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/marginCommon"
                android:textColor="#5328de "
                android:textSize="@dimen/textSize_10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mar20dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/herbal_iv_modifyB"
                android:layout_width="54dp"
                android:layout_height="24dp"
                android:layout_marginRight="@dimen/marginCommon"
                android:src="@mipmap/ic_modify"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/herbal_iv_commit"
                android:layout_width="54dp"
                android:layout_height="24dp"
                android:layout_marginLeft="@dimen/marginCommon"
                android:src="@mipmap/ic_commit"
                android:visibility="visible" />
        </LinearLayout>


    </LinearLayout>
</LinearLayout>