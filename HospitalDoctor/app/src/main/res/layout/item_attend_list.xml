<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/mar30dp"
    android:id="@+id/attenLinear"
    >

    <View style="@style/view_commonVert" />

    <TextView
        android:id="@+id/attend_item_date"
        android:layout_width="@dimen/size0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:gravity="center"
        android:textColor="@color/textBlack"
        android:textSize="@dimen/textSize_12sp" />

    <View style="@style/view_commonVert" />

    <RelativeLayout
        android:layout_width="@dimen/size0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:id="@+id/item_iv_swbz"
            android:layout_width="@dimen/mar10dp"
            android:layout_height="@dimen/mar10dp" />
    </RelativeLayout>

    <View style="@style/view_commonVert" />

    <RelativeLayout
        android:layout_width="@dimen/size0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:id="@+id/item_iv_xwbz"
            android:layout_width="@dimen/mar10dp"
            android:layout_height="@dimen/mar10dp" />
    </RelativeLayout>

    <View style="@style/view_commonVert" />

    <RelativeLayout
        android:layout_width="@dimen/size0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center">

        <ImageView
            android:id="@+id/item_iv_wsbz"
            android:layout_width="@dimen/mar10dp"
            android:layout_height="@dimen/mar10dp" />
    </RelativeLayout>

    <View style="@style/view_commonVert" />
</LinearLayout>