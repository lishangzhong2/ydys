<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="188dp"
    android:layout_height="match_parent"
    android:background="@drawable/bg_stroke"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="33dp"
        android:background="#1669b2">

        <EditText
            android:id="@+id/main_navEdit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/drawable_padding_5dp"
            android:layout_marginLeft="@dimen/mar10dp"
            android:layout_marginRight="@dimen/mar10dp"
            android:layout_marginTop="@dimen/drawable_padding_5dp"
            android:background="@drawable/edit_round_bg"
            android:hint="@string/inputNameBednum"
            android:paddingLeft="@dimen/drawable_padding_3dp"
            android:paddingStart="@dimen/drawable_padding_3dp"
            android:textColor="#999"
            android:textSize="11sp"
            tools:ignore="RtlSymmetry,SmallSp"
            android:visibility="gone"/>
    </LinearLayout>

    <android.support.v7.widget.RecyclerView
        android:id="@+id/main_cardList"
        android:layout_width="188dp"
        android:layout_marginTop="@dimen/padding7dp"
        android:layout_height="match_parent"
        android:paddingLeft="@dimen/padding7dp"
        android:paddingRight="@dimen/padding7dp"
        />
</LinearLayout>