            android:src="@drawable/nav_baogao_selector" />

        <!--<ImageView
            android:id="@+id/nav_iv_beiwang"
            style="@style/navImageStyle"
            android:layout_marginTop="@dimen/navIconSpace"
            android:src="@drawable/nav_bw_selector" />-->

        <ImageView
            android:id="@+id/nav_iv_lj"
            style="@style/navImageStyle"
            android:layout_marginTop="@dimen/navIconSpace"
            android:onClick="onTabClick"
            android:src="@drawable/nav_lj_selector"
